# .env.test — used automatically when NODE_ENV=test
# Safe dummy values — never use real credentials here.

NODE_ENV=test
PORT=5001
API_VERSION=v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentorminds_test
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mentorminds_test
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=test-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

CORS_ORIGIN=http://localhost:3000

REDIS_URL=redis://localhost:6379

LOG_LEVEL=error

SECRETS_PROVIDER=env

SENTRY_DSN=
ENCRYPTION_KEY=test-encryption-key-at-least-32-characters-long
