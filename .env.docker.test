# Jest + Docker Compose test stack (service hostnames: postgres, redis)
# POSTGRES_* are read by the postgres container; DB_* / DATABASE_URL by the API tests.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=mentorminds_test

NODE_ENV=test
PORT=5000
API_VERSION=v1
DATABASE_URL=postgresql://postgres:testpassword@postgres:5432/mentorminds_test
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mentorminds_test
DB_USER=postgres
DB_PASSWORD=testpassword
JWT_SECRET=test-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-key-minimum-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REDIS_URL=redis://redis:6379
LOG_LEVEL=error
BCRYPT_ROUNDS=1
PLATFORM_FEE_PERCENTAGE=5
MEETING_PROVIDER=jitsi
MEETING_API_KEY=

AWS_S3_BUCKET=test-bucket
AWS_ACCESS_KEY_ID=test-key
AWS_SECRET_ACCESS_KEY=test-secret
