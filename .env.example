# =============================================================================
# MentorMinds Backend — Environment Variables
# Copy this file to .env and fill in your values.
# For local overrides (developer machines), create .env.local — it takes
# precedence over .env and should never be committed to version control.
# =============================================================================
DAILY_API_KEY=
WHEREBY_API_KEY=
VIDEO_PROVIDER=daily
# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development           # development | test | production
PORT=5000                      # Port the HTTP server listens on
API_VERSION=v1                 # API version prefix (e.g. /api/v1)

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — DATABASE_URL is required
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mentorminds
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mentorminds
DB_USER=postgres
DB_PASSWORD=your_password      # Required — never commit real passwords

# -----------------------------------------------------------------------------
# JWT — secrets must be at least 32 characters
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-32-char-minimum-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-a-different-random-32-char-secret
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Stellar Network
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet        # testnet | mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

STELLAR_FUNDING_SECRET=

# Platform wallet — leave blank in development if not needed
PLATFORM_PUBLIC_KEY=
PLATFORM_SECRET_KEY=           # Sensitive — never log or expose this value

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000    # Window in ms (default: 15 minutes)
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window per IP

# Auth endpoints
RATE_LIMIT_AUTH_MAX=10         # Max auth attempts per 15 min window (default: 10)

# API endpoints (authenticated)
RATE_LIMIT_API_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_API_MAX=60          # Max requests per minute per user

# Sensitive endpoints (password reset, etc.)
RATE_LIMIT_SENSITIVE_MAX=5     # Max per hour

# -----------------------------------------------------------------------------
# Redis (optional — used for caching and session storage)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Docker Compose (local stack: api + postgres + redis)
# -----------------------------------------------------------------------------
# When using `npm run docker:dev` or `docker compose up`, point DB/Redis at service names:
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
# DB_HOST=postgres
# REDIS_URL=redis://redis:6379
# Copy this file to `.env` and fill credentials before running compose (no secrets in YAML).

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                # debug | info | warn | error
LOG_FILE_PATH=logs             # Directory for rotated log files (production only)
LOG_MAX_SIZE=20m               # Max size per log file before rotation
LOG_MAX_FILES=14d              # Retention period for rotated log files

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=10               # Cost factor for password hashing
ENCRYPTION_KEY=change-this-to-a-random-32-char-minimum-secret  # AES-256 encryption key
MFA_TOTP_ISSUER=MentorMinds     # Issuer name shown in authenticator apps

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------
PLATFORM_FEE_PERCENTAGE=5      # Percentage fee taken on each transaction

# -----------------------------------------------------------------------------
# Meeting Provider (Video Conferencing)
# -----------------------------------------------------------------------------
# Options: daily, whereby, zoom, jitsi
# - Daily.co: Professional video rooms with API (https://daily.co)
# - Whereby: Simple embedded video rooms (https://whereby.com)
# - Zoom: Enterprise video conferencing (https://zoom.us)
# - Jitsi: Free, self-hosted option (https://jitsi.org)
MEETING_PROVIDER=daily          # Choose one: daily, whereby, zoom, jitsi
MEETING_API_KEY=your_api_key_here  # Required for Daily, Whereby, Zoom
MEETING_API_SECRET=              # Optional: Additional secret for some providers
MEETING_ROOM_EXPIRY_MINUTES=30   # Meeting rooms expire 30 minutes after session end
MEETING_RETRY_ATTEMPTS=1         # Number of retry attempts if provider API fails

# Jitsi specific (only needed if using self-hosted Jitsi)
JITSI_BASE_URL=https://meet.jit.si

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (Push Notifications)
# -----------------------------------------------------------------------------
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# -----------------------------------------------------------------------------
# Error Monitoring & Tracking
# -----------------------------------------------------------------------------
# Sentry - Get your DSN from https://sentry.io > Project Settings > Client Keys
# Leave blank to disable Sentry (e.g. in local development)
SENTRY_DSN=

# DataDog - Get credentials from https://app.datadoghq.com > Organization Settings > API Keys
# Leave blank to disable DataDog logging
DATADOG_CLIENT_TOKEN=
DATADOG_SITE=datadoghq.com     # Options: datadoghq.com, datadoghq.eu, us3.datadoghq.com, etc.

# -----------------------------------------------------------------------------
# Secrets Management
# -----------------------------------------------------------------------------
# SECRETS_PROVIDER=env        # env (default) | aws | vault
#
# AWS Secrets Manager (SECRETS_PROVIDER=aws):
# AWS_REGION=us-east-1
# AWS_SECRET_ID=mentorminds/prod/app-secrets
#
# HashiCorp Vault (SECRETS_PROVIDER=vault):
# VAULT_ADDR=https://vault.internal
# VAULT_TOKEN=your-vault-token
# VAULT_SECRET_PATH=secret/data/mentorminds/prod
SECRETS_PROVIDER=env

# JWT key rotation — set during rotation, remove after old tokens expire
# JWT_SECRET_PREVIOUS=

# -----------------------------------------------------------------------------
# OAuth2 / Social Login
# -----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000
