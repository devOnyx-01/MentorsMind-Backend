# =============================================================================
# MentorMinds Backend — Environment Variables
# Copy this file to .env and fill in your values.
# For local overrides (developer machines), create .env.local — it takes
# precedence over .env and should never be committed to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development           # development | test | production
PORT=5000                      # Port the HTTP server listens on
API_VERSION=v1                 # API version prefix (e.g. /api/v1)

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — DATABASE_URL is required
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mentorminds
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mentorminds
DB_USER=postgres
DB_PASSWORD=your_password      # Required — never commit real passwords

# -----------------------------------------------------------------------------
# JWT — secrets must be at least 32 characters
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-32-char-minimum-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-a-different-random-32-char-secret
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Stellar Network
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet        # testnet | mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Platform wallet — leave blank in development if not needed
PLATFORM_PUBLIC_KEY=
PLATFORM_SECRET_KEY=           # Sensitive — never log or expose this value

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000    # Window in ms (default: 15 minutes)
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window per IP

# Auth endpoints
RATE_LIMIT_AUTH_MAX=10         # Max auth attempts per 15 min window (default: 10)

# API endpoints (authenticated)
RATE_LIMIT_API_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_API_MAX=60          # Max requests per minute per user

# Sensitive endpoints (password reset, etc.)
RATE_LIMIT_SENSITIVE_MAX=5     # Max per hour

# -----------------------------------------------------------------------------
# Redis (optional — used for caching and session storage)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                # debug | info | warn | error

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=10               # Cost factor for password hashing

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------
PLATFORM_FEE_PERCENTAGE=5      # Percentage fee taken on each transaction
