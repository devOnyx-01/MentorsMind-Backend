{
  "name": "mentorminds-backend",
  "version": "1.0.0",
  "description": "MentorMinds Stellar - Backend API Server",
  "main": "dist/bootstrap.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/bootstrap.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bootstrap.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest -c jest.unit.config.ts",
    "test:watch": "jest -c jest.unit.config.ts --watch",
    "test:coverage": "jest -c jest.unit.config.ts --coverage",
    "test:all": "jest",
    "test:security": "jest -c jest.unit.config.ts src/__tests__/security",
    "test:security:watch": "jest -c jest.unit.config.ts src/__tests__/security --watch",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "seed": "ts-node --project tsconfig.seed.json database/seeds/index.ts",
    "seed:reset": "ts-node --project tsconfig.seed.json database/seeds/index.ts --reset",
    "seed:test": "ts-node --project tsconfig.seed.json database/seeds/index.ts --size=test",
    "migrate:up": "node-pg-migrate up --database-url-var DATABASE_URL --migrations-dir database/migrations",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migrations-dir database/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir database/migrations",
    "docker:build": "docker compose build",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:test": "docker compose --env-file .env.docker.test -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from test-backend",
    "prepare": "husky"
  },
  "keywords": [
    "mentorminds",
    "stellar",
    "blockchain",
    "api",
    "express"
  ],
  "author": "MentorMinds Team",
  "license": "MIT",
  "type": "commonjs",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "@types/archiver": "^7.0.0",
    "@types/multer": "^2.1.0",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "cron": "^3.1.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-jaeger": "^1.30.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "@apollo/server": "^4.13.0",
    "graphql": "^16.8.0",
    "dataloader": "^2.2.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.0",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.4.2",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "@types/node-pg-migrate": "^2.3.1",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "openapi-diff": "^0.24.1",
    "openapi-typescript": "^7.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
