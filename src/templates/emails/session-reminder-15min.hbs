{{#> base-layout}}
{{#*inline "content"}}
<h2 style="color: #4A90E2; margin: 0 0 20px 0; font-size: 24px;">Session Starting Soon! ⏰</h2>

<p style="margin: 0 0 20px 0;">
    Hi {{userName}},
</p>

<p style="margin: 0 0 20px 0;">
    Your mentoring session is starting in 15 minutes! Please get ready to join.
</p>

<div
    style="background-color: #e8f4fd; padding: 20px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #4A90E2;">
    <h3 style="margin: 0 0 15px 0; color: #333; font-size: 18px;">Session Details</h3>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px; width: 40%;">
                <strong>Mentor:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{mentorName}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Time:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{sessionTime}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Duration:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{duration}} minutes
            </td>
        </tr>
        {{#if meetingUrl}}
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Meeting Link:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                <a href="{{meetingUrl}}" style="color: #4A90E2; font-weight: bold;">Join Now</a>
            </td>
        </tr>
        {{/if}}
    </table>
</div>

{{#if meetingUrl}}
<div style="text-align: center; margin: 30px 0;">
    <a href="{{meetingUrl}}"
        style="display: inline-block; background-color: #28a745; color: #ffffff; text-decoration: none; padding: 14px 30px; border-radius: 6px; font-weight: bold; font-size: 16px;">
        Join Session Now
    </a>
</div>
{{/if}}

<div
    style="background-color: #d4edda; padding: 15px; border-radius: 6px; margin: 20px 0; border-left: 4px solid #28a745;">
    <p style="margin: 0; color: #155724; font-size: 14px;">
        <strong>Quick Checklist:</strong><br>
        ✓ Test your audio and video<br>
        ✓ Ensure stable internet connection<br>
        ✓ Have your questions ready<br>
        ✓ Find a quiet space
    </p>
</div>

<p style="margin: 20px 0 0 0; color: #666; font-size: 14px;">
    Have a great session!
</p>
{{/inline}}
{{/base-layout}}