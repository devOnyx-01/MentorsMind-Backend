{{#> base-layout}}
{{#*inline "content"}}
<h2 style="color: #4A90E2; margin: 0 0 20px 0; font-size: 24px;">Booking Confirmed! 🎉</h2>

<p style="margin: 0 0 20px 0;">
    Hi {{userName}},
</p>

<p style="margin: 0 0 20px 0;">
    Great news! Your mentoring session has been confirmed. Here are the details:
</p>

<div
    style="background-color: #e8f4fd; padding: 20px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #4A90E2;">
    <h3 style="margin: 0 0 15px 0; color: #333; font-size: 18px;">Session Details</h3>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px; width: 40%;">
                <strong>Mentor:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{mentorName}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Date:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{sessionDate}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Time:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{sessionTime}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Duration:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{duration}} minutes
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Amount:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{amount}} XLM
            </td>
        </tr>
        {{#if meetingUrl}}
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Meeting Link:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                <a href="{{meetingUrl}}" style="color: #4A90E2;">{{meetingUrl}}</a>
            </td>
        </tr>
        {{/if}}
    </table>
</div>

<div style="text-align: center; margin: 30px 0;">
    <a href="{{bookingDetailsUrl}}"
        style="display: inline-block; background-color: #4A90E2; color: #ffffff; text-decoration: none; padding: 14px 30px; border-radius: 6px; font-weight: bold; font-size: 16px;">
        View Booking Details
    </a>
</div>

<div
    style="background-color: #d4edda; padding: 15px; border-radius: 6px; margin: 20px 0; border-left: 4px solid #28a745;">
    <p style="margin: 0; color: #155724; font-size: 14px;">
        <strong>Reminder:</strong> Please be ready 5 minutes before your session. If you need to cancel or reschedule,
        please do so at least 24 hours in advance.
    </p>
</div>

<p style="margin: 20px 0 0 0; color: #666; font-size: 14px;">
    We hope you have a productive session!
</p>
{{/inline}}
{{/base-layout}}