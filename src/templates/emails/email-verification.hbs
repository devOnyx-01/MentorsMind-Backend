{{#> base-layout}}
{{#*inline "content"}}
<h2 style="color: #4A90E2; margin: 0 0 20px 0; font-size: 24px;">Verify Your Email Address</h2>

<p style="margin: 0 0 20px 0;">
    Hi {{userName}},
</p>

<p style="margin: 0 0 20px 0;">
    Thank you for signing up for MentorMinds! Please verify your email address to complete your registration and unlock
    all features.
</p>

<div style="text-align: center; margin: 30px 0;">
    <a href="{{verificationUrl}}"
        style="display: inline-block; background-color: #28a745; color: #ffffff; text-decoration: none; padding: 14px 30px; border-radius: 6px; font-weight: bold; font-size: 16px;">
        Verify Email Address
    </a>
</div>

<div
    style="background-color: #fff3cd; padding: 15px; border-radius: 6px; margin: 20px 0; border-left: 4px solid #ffc107;">
    <p style="margin: 0; color: #856404; font-size: 14px;">
        <strong>Note:</strong> This verification link will expire in 24 hours. If you didn't create an account, you can
        safely ignore this email.
    </p>
</div>

<p style="margin: 20px 0 0 0; color: #666; font-size: 14px;">
    If the button above doesn't work, copy and paste this link into your browser:<br>
    <a href="{{verificationUrl}}" style="color: #4A90E2; word-break: break-all;">{{verificationUrl}}</a>
</p>
{{/inline}}
{{/base-layout}}